// REMINDER PICKER
// ========================================
function showReminderPicker(prospectId,name){
  openModal(`
    <h3>Programmer un <span>rappel</span></h3>
    <p style="font-size:.82rem;color:var(--gray);margin-bottom:16px">${escHtml(name)}</p>
    <div class="modal-field"><label>Date et heure</label><input type="datetime-local" id="reminderDate"></div>
    <div class="modal-field"><label>Notes</label><textarea id="reminderNotes" placeholder="Raison du rappel..."></textarea></div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeModal()">Annuler</button>
      <button class="btn btn-accent" onclick="saveReminder(${prospectId},'${esc(name)}')">Sauvegarder</button>
    </div>
  `);
}

async function saveReminder(prospectId,name){
  const date=document.getElementById('reminderDate').value;
  const notes=document.getElementById('reminderNotes').value.trim();
  if(!date){showToast('Erreur','Date requise','var(--red)');return}
  await sb.from('reminders').insert([{
    prospect_id:prospectId,
    prospect_name:name,
    vendor:currentUser,
    remind_at:new Date(date).toISOString(),
    notes,
    status:'pending'
  }]);
  const{data}=await sb.from('reminders').select('*').order('remind_at');
  REMINDERS=data||[];
  closeModal();
  showToast('Rappel programme','','var(--green)');
}

