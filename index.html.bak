  {id:'unstoppable_force',cat:'Special',name:'Unstoppable Force',desc:'10 sales in a month',points:600,rarity:'Legendary',secret:true,icon:'<svg viewBox="0 0 24 24" width="32" height="32"><polygon points="12,2 14,10 22,10 16,15 18,22 12,18 6,22 8,15 2,10 10,10" fill="none" stroke="#f85149" stroke-width="2"/><polygon points="12,6 13.5,10 17,10 14,12.5 15,16 12,14 9,16 10,12.5 7,10 10.5,10" fill="#f85149"/></svg>'},
  {id:'the_goat',cat:'Special',name:'The GOAT',desc:'Highest all-time revenue',points:1500,rarity:'Legendary',secret:true,icon:'<svg viewBox="0 0 24 24" width="32" height="32"><path d="M5 16L3 5l5.5 5L12 2l3.5 8L21 5l-2 11H5z" fill="none" stroke="#d29922" stroke-width="2.5"/><path d="M5 19h14v3H5z" fill="#d29922"/></svg>'},
  {id:'completionist',cat:'Special',name:'Completionist',desc:'Unlock 50 badges',points:1000,rarity:'Legendary',secret:true,icon:'<svg viewBox="0 0 24 24" width="32" height="32"><circle cx="12" cy="12" r="10" fill="none" stroke="#bc8cff" stroke-width="2"/><path d="M8 12l3 3 5-6" fill="none" stroke="#bc8cff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>'},
  {id:'vantage_champion',cat:'Special',name:'Vantage Champion',desc:'Unlock 80 badges',points:2500,rarity:'Legendary',secret:true,icon:'<svg viewBox="0 0 24 24" width="32" height="32"><polygon points="12,1 15,8 22,9 17,14 18,21 12,18 6,21 7,14 2,9 9,8" fill="#d29922" opacity=".3"/><polygon points="12,1 15,8 22,9 17,14 18,21 12,18 6,21 7,14 2,9 9,8" fill="none" stroke="#d29922" stroke-width="2.5"/><path d="M8 12l3 3 5-6" fill="none" stroke="#d29922" stroke-width="2.5" stroke-linecap="round"/></svg>'}
];

// ========================================
// EXPORT CSV
// ========================================
function exportCSV(){
  let csv='nom,numero,type_tel,famille,categorie,region,adresse,vendeur,statut,notes\n';
  DATA.forEach(d=>{csv+='"'+(d.nom||'')+'","'+(d.numero||'')+'","'+(d.type_tel||'')+'","'+(d.famille||'')+'","'+(d.categorie||'')+'","'+(d.region||'')+'","'+(d.adresse||'')+'","'+(d.vendeur||'')+'","'+(d.status||'')+'","'+((d.notes||'').replace(/"/g,'""'))+'"\n'});
  const b=new Blob([csv],{type:'text/csv'});const a=document.createElement('a');a.href=URL.createObjectURL(b);a.download='vantage_prospects.csv';a.click();
}

// ========================================
// PDF REPORT
// ========================================
function generatePDFReport(){
  if(!isAdmin)return;
  const{jsPDF}=window.jspdf;
  const doc=new jsPDF();
  const now=new Date();

  doc.setFontSize(20);doc.setTextColor(88,166,255);
  doc.text('VANTAGE CRM - Report',14,20);
  doc.setFontSize(10);doc.setTextColor(139,148,158);
  doc.text('Generated: '+now.toLocaleString('fr-FR'),14,28);

  let y=44;
  doc.setFontSize(14);doc.setTextColor(230,237,243);
  doc.text('Team Summary',14,y);y+=10;

  const totalWon=DATA.filter(d=>d.status==='valide').length;
  const totalLost=DATA.filter(d=>d.status==='perdu').length;
  const totalNego=DATA.filter(d=>d.status==='negociation').length;
  const totalRevenue=totalWon*500;

  doc.setFontSize(10);doc.setTextColor(139,148,158);
  doc.text('Total: '+TOTAL_COUNT+' | Won: '+totalWon+' | Lost: '+totalLost+' | Nego: '+totalNego,14,y);y+=6;
  doc.text('Revenue: '+totalRevenue.toLocaleString()+' EUR',14,y);y+=14;

  doc.setFontSize(14);doc.setTextColor(230,237,243);
  doc.text('Vendor Statistics',14,y);y+=10;

  VENDOR_NAMES.forEach(v=>{
    const stats=getVendorStats(v);
    const pts=calcPoints(v);
    doc.setFontSize(11);doc.setTextColor(88,166,255);
    doc.text(v,14,y);y+=7;
    doc.setFontSize(9);doc.setTextColor(139,148,158);
    doc.text('Calls: '+stats.calls+' | Won: '+stats.wins+' | Nego: '+stats.nego+' | Points: '+pts,20,y);y+=5;
    doc.text('Revenue: '+stats.rev.toLocaleString()+' EUR | Conv: '+stats.conv+'%',20,y);y+=10;
    if(y>270){doc.addPage();y=20;}
  });

  doc.save('vantage_report_'+now.toISOString().slice(0,10)+'.pdf');
  showToast('PDF genere','Rapport telecharge.','var(--green)');
}

// ========================================
// REALTIME SUBSCRIPTIONS
// ========================================
sb.channel('changes').on('postgres_changes',{event:'*',schema:'public',table:'prospects'},p=>{
  if(p.eventType==='UPDATE'){
    const i=DATA.findIndex(d=>d.id===p.new.id);
    if(p.new.blacklisted){
      if(i>=0)DATA.splice(i,1);
    } else {
      if(i>=0)DATA[i]=p.new;
      else DATA.push(p.new);
    }
  }
  else if(p.eventType==='INSERT'){
    if(!p.new.blacklisted)DATA.push(p.new);
  }
  render();
}).subscribe();

sb.channel('proj-changes').on('postgres_changes',{event:'*',schema:'public',table:'projects'},async()=>{
  const{data}=await sb.from('projects').select('*').order('id');PROJECTS=data||[];render();
}).subscribe();

sb.channel('client-changes').on('postgres_changes',{event:'*',schema:'public',table:'clients'},async()=>{
  const{data}=await sb.from('clients').select('*').order('id');CLIENTS=data||[];render();
}).subscribe();

sb.channel('reminder-changes').on('postgres_changes',{event:'*',schema:'public',table:'reminders'},async()=>{
  const{data}=await sb.from('reminders').select('*').order('remind_at');REMINDERS=data||[];
  if(currentTab==='reminders')render();
}).subscribe();

sb.channel('blacklist-changes').on('postgres_changes',{event:'*',schema:'public',table:'blacklist'},async()=>{
  const{data}=await sb.from('blacklist').select('*').order('id');BLACKLIST=data||[];
  const blIds=new Set(BLACKLIST.map(b=>b.prospect_id));
  DATA=DATA.filter(d=>!blIds.has(d.id));
  render();
}).subscribe();

sb.channel('callhistory-changes').on('postgres_changes',{event:'*',schema:'public',table:'call_history'},async()=>{
  const{data}=await sb.from('call_history').select('*').order('created_at',{ascending:false}).limit(500);
  CALL_HISTORY=data||[];
}).subscribe();

// ========================================
// BADGE CHECK INTERVAL
// ========================================
setInterval(()=>{
  if(currentUser&&!isAdmin){
    checkBadges(currentUser);
  }
},30000);

// ========================================
// GSAP LOGIN ANIMATION
// ========================================
gsap.registerPlugin(ScrollTrigger);

// ====== GLASSMORPHISM TOOLTIPS ======
let tooltipEl=null;
let tooltipTimeout=null;
document.addEventListener('mouseover',function(e){
  const target=e.target.closest('[title]');
  if(!target||!target.title)return;
  const text=target.title;
  target.dataset.tooltip=text;
  target.removeAttribute('title');
  clearTimeout(tooltipTimeout);
  tooltipTimeout=setTimeout(()=>{
    if(!tooltipEl){
      tooltipEl=document.createElement('div');
      tooltipEl.className='glass-tooltip';
      document.body.appendChild(tooltipEl);
    }
    tooltipEl.textContent=text;
    const rect=target.getBoundingClientRect();
    tooltipEl.style.left=rect.left+'px';
    tooltipEl.style.top=(rect.top-32)+'px';
    tooltipEl.classList.add('visible');
  },200);
});
document.addEventListener('mouseout',function(e){
  const target=e.target.closest('[data-tooltip]');
  if(!target)return;
  target.title=target.dataset.tooltip;
  delete target.dataset.tooltip;
  clearTimeout(tooltipTimeout);
  if(tooltipEl)tooltipEl.classList.remove('visible');
});

gsap.fromTo('.login-box',{y:30,opacity:0},{y:0,opacity:1,duration:.8,ease:'power3.out',delay:.3});
</script>
</body>
</html>
