  customObjectives=[];
  openModal(`
    <h3>Modifier <span>Projet</span></h3>
    <div class="modal-field"><label>Nom</label><input id="editProjName" value="${escHtml(p.name)}"></div>
    <div class="modal-field"><label>Region</label><select id="editProjRegion">${ALL_REGIONS.map(r=>`<option value="${escHtml(r)}"${p.region===r?' selected':''}>${escHtml(r)}</option>`).join('')}</select></div>
    <div class="modal-field"><label>Vendeur</label><select id="editProjVendeur"><option value="Tous"${p.vendeur==='Tous'?' selected':''}>Tous</option>${VENDOR_NAMES.map(v=>`<option value="${v}"${p.vendeur===v?' selected':''}>${v}</option>`).join('')}</select></div>
    <div class="modal-field"><label>Statut</label><select id="editProjStatus"><option value="active"${p.status==='active'?' selected':''}>Actif</option><option value="paused"${p.status==='paused'?' selected':''}>En pause</option><option value="completed"${p.status==='completed'?' selected':''}>Termine</option></select></div>
    <div class="modal-field"><label>Description</label><textarea id="editProjDesc">${escHtml(p.description||'')}</textarea></div>
    <div class="modal-field"><label>Objectifs</label>
      <div id="editProjObjectives" style="display:flex;flex-direction:column;gap:6px">
        <label style="font-size:.72rem;display:flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" class="obj-check" value="conquer_island"> Conquer an entire island (100% region)</label>
        <label style="font-size:.72rem;display:flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" class="obj-check" value="conquer_2_islands"> Conquer 2 islands</label>
        <label style="font-size:.72rem;display:flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" class="obj-check" value="win_5_sales"> Win 5 sales in region</label>
        <label style="font-size:.72rem;display:flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" class="obj-check" value="win_10_sales"> Win 10 sales in region</label>
        <label style="font-size:.72rem;display:flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" class="obj-check" value="gen_2500"> Generate 2500&#8364; from region</label>
        <label style="font-size:.72rem;display:flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" class="obj-check" value="gen_5000"> Generate 5000&#8364; from region</label>
        <label style="font-size:.72rem;display:flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" class="obj-check" value="call_50_pct"> Call 50% of prospects in 1 week</label>
        <label style="font-size:.72rem;display:flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" class="obj-check" value="call_100_in_3d"> Call 100 prospects in 3 days</label>
        <label style="font-size:.72rem;display:flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" class="obj-check" value="get_20_interested"> Get 20 interested clients</label>
        <label style="font-size:.72rem;display:flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" class="obj-check" value="zero_losses"> Zero losses - win 5 with 0 lost</label>
      </div>
      <div style="margin-top:8px">
        <div id="editCustomObjList"></div>
        <div style="display:flex;gap:6px;margin-top:6px"><input class="search" id="editCustomObjInput" placeholder="Add custom objective..." style="flex:1;width:auto"><button class="btn btn-ghost btn-sm" onclick="addCustomObj('edit')">+ Add</button></div>
      </div>
