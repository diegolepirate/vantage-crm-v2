async function saveEditProject(id){
  const obj={
    name:document.getElementById('editProjName').value.trim(),
    region:document.getElementById('editProjRegion').value,
    vendeur:document.getElementById('editProjVendeur').value,
    status:document.getElementById('editProjStatus').value,
    description:document.getElementById('editProjDesc').value.trim(),
    updated_at:new Date().toISOString()
  };
  await sb.from('projects').update(obj).eq('id',id);
  await saveEditProjectObjectives(id);
  const p=PROJECTS.find(x=>x.id===id);
  if(p)Object.assign(p,obj);
  closeModal();
  showToast('Projet modifie','Modifications sauvegardees','var(--green)');
  render();
}

function confirmDeleteProject(id){
  showConfirmModal('Supprimer ce projet ?',async()=>{
    await sb.from('projects').delete().eq('id',id);
    PROJECTS=PROJECTS.filter(p=>p.id!==id);
    showToast('Projet supprime','','var(--red)');
    render();
  });
}

// ====== OBJECTIVES SYSTEM ======
let customObjectives=[];
function addCustomObj(prefix){
  const inputId=prefix?prefix+'CustomObjInput':'customObjInput';
  const listId=prefix?prefix+'CustomObjList':'customObjList';
  const inp=document.getElementById(inputId);
  if(!inp||!inp.value.trim())return;
  const val=inp.value.trim();
  customObjectives.push(val);
  inp.value='';
  const list=document.getElementById(listId);
  if(list){
    const div=document.createElement('div');
    div.style.cssText='display:flex;align-items:center;gap:8px;font-size:.72rem;padding:4px 0';
    div.innerHTML='<input type="checkbox" class="obj-check" value="custom_'+customObjectives.length+'" checked> '+escHtml(val)+' <button class="btn btn-ghost btn-sm" onclick="this.parentElement.remove()" style="padding:2px 6px;font-size:.55rem">x</button>';
    list.appendChild(div);
  }
}

function getSelectedObjectives(containerId){
  const container=document.getElementById(containerId);
  if(!container)return[];
  const checks=container.parentElement.querySelectorAll('.obj-check:checked');
  return Array.from(checks).map(c=>{
    const label=c.parentElement?c.parentElement.textContent.trim():'';
    return{id:c.value,label:label};
  });
}

async function saveProjectObjectives(projectId){
  const objs=getSelectedObjectives('projObjectives');
  await sb.from('project_objectives').delete().eq('project_id',projectId);
  if(objs.length){
    const rows=objs.map(o=>({project_id:projectId,type:o.id.startsWith('custom_')?'custom':'preset',description:o.label}));
    await sb.from('project_objectives').insert(rows);
  }
}

async function saveEditProjectObjectives(projectId){
  const objs=getSelectedObjectives('editProjObjectives');
  await sb.from('project_objectives').delete().eq('project_id',projectId);
  if(objs.length){
    const rows=objs.map(o=>({project_id:projectId,type:o.id.startsWith('custom_')?'custom':'preset',description:o.label}));
    await sb.from('project_objectives').insert(rows);
  }
}

let OBJECTIVES_CACHE={};
async function loadAllObjectives(){
  const{data}=await sb.from('project_objectives').select('*');
  OBJECTIVES_CACHE={};
  (data||[]).forEach(o=>{
    if(!OBJECTIVES_CACHE[o.project_id])OBJECTIVES_CACHE[o.project_id]=[];
    OBJECTIVES_CACHE[o.project_id].push({id:o.type==='custom'?'custom_'+o.id:o.description.toLowerCase().replace(/\s+/g,'_'),label:o.description,completed:o.completed});
  });
}
function loadProjectObjectives(projectId){
  return OBJECTIVES_CACHE[projectId]||[];
}

function loadObjectivesIntoEditModal(projectId){
  const objs=loadProjectObjectives(projectId);
  setTimeout(function(){
    const container=document.getElementById('editProjObjectives');
    if(!container)return;
    objs.forEach(function(o){
      const check=container.querySelector('input[value="'+o.id+'"]');
      if(check)check.checked=true;
      else if(o.id.startsWith('custom_')){
        const list=document.getElementById('editCustomObjList');
        if(list){
          const div=document.createElement('div');
          div.style.cssText='display:flex;align-items:center;gap:8px;font-size:.72rem;padding:4px 0';
          div.innerHTML='<input type="checkbox" class="obj-check" value="'+escHtml(o.id)+'" checked> '+escHtml(o.label)+' <button class="btn btn-ghost btn-sm" onclick="this.parentElement.remove()" style="padding:2px 6px;font-size:.55rem">x</button>';
          list.appendChild(div);
        }
      }
    });
  },50);
}

function viewProjectProspects(region,vendeur){
  ownerFilter='all';
  statusFilter='';
  switchTab('prospects');
  setTimeout(()=>{
    const regEl=document.getElementById('fReg');
    if(regEl)regEl.value=region;
    if(vendeur&&vendeur!=='Tous'){
      const venEl=document.getElementById('fVen');
      if(venEl)venEl.value=vendeur;
    }
    reloadAndRender();
  },100);
}

// ========================================
// 4. LEADERBOARD TAB
// ========================================
function renderLeaderboard(container){
  const rankings=VENDOR_NAMES.map(v=>{
    const stats=getVendorStats(v);
    return{name:v,pts:calcPoints(v),calls:stats.calls,wins:stats.wins,lost:stats.lost,rev:stats.rev,conv:stats.conv};
  }).sort((a,b)=>b.pts-a.pts);

  let html=`<div class="leaderboard-wrap">
    <h2 style="font-size:1.2rem;font-weight:800;margin-bottom:24px">Classement en temps reel</h2>`;

  rankings.forEach((r,i)=>{
    const rank=i+1;
    const crown=rank===1?' <span class="lb-crown">&#128081;</span>':'';
    html+=`<div class="lb-card ${rank===1?'rank-1':''}">
      <div class="lb-rank r${rank}">#${rank}</div>
      <div class="lb-name">${r.name}${crown}${getStreakIcon(r.name)}</div>
      <div class="lb-stats">
        <div class="lb-stat"><div class="lb-stat-val" style="color:var(--yellow)">${r.pts}</div><div class="lb-stat-lbl">Points</div></div>
        <div class="lb-stat"><div class="lb-stat-val" style="color:var(--accent)">${r.calls}</div><div class="lb-stat-lbl">Appels</div></div>
        <div class="lb-stat"><div class="lb-stat-val" style="color:var(--green)">${r.wins}</div><div class="lb-stat-lbl">Gagnes</div></div>
        <div class="lb-stat"><div class="lb-stat-val" style="color:var(--red)">${r.lost}</div><div class="lb-stat-lbl">Perdus</div></div>
        <div class="lb-stat"><div class="lb-stat-val" style="color:var(--green)">${r.rev.toLocaleString()}&#8364;</div><div class="lb-stat-lbl">Revenue</div></div>
        <div class="lb-stat"><div class="lb-stat-val" style="color:var(--purple)">${r.conv}%</div><div class="lb-stat-lbl">Conv.</div></div>
      </div>
    </div>`;
  });

  html+=`</div>`;
  container.innerHTML=html;
  gsap.from('.lb-card',{x:-30,opacity:0,stagger:0.1,duration:0.5,ease:'power2.out'});
}

// ========================================
// 5. BADGES TAB
// ========================================
function renderBadges(container){
  const vendor=isAdmin?null:currentUser;
  let html=`<div class="badges-wrap">`;

  if(isAdmin){
    html+=`<h2 style="font-size:1.2rem;font-weight:800;margin-bottom:16px">Badges Vendeurs</h2>`;
    html+=`<div style="display:flex;gap:12px;margin-bottom:24px;flex-wrap:wrap">`;
    VENDOR_NAMES.forEach(v=>{
      const badges=getBadges(v);
      const unlocked=Object.values(badges).filter(b=>b.unlocked).length;
      html+=`<button class="btn btn-ghost" onclick="renderBadgesForVendor('${v}')" style="font-size:.75rem">${v} <span style="color:var(--accent);margin-left:4px">${unlocked}/${BADGE_DEFS.length}</span></button>`;
    });
    html+=`</div><div id="badgesContent"></div>`;
  } else {
    html+=renderBadgesContent(currentUser);
  }

  html+=`</div>`;
  container.innerHTML=html;

  if(isAdmin){
    document.getElementById('badgesContent').innerHTML=renderBadgesContent(VENDOR_NAMES[0]);
  }
  gsap.from('.badge-card',{scale:0.8,opacity:0,stagger:0.03,duration:0.4,ease:'back.out(1.4)'});
}

function renderBadgesForVendor(v){
  document.getElementById('badgesContent').innerHTML=renderBadgesContent(v);
}

function renderBadgesContent(vendor){
  const badges=getBadges(vendor);
  const unlocked=Object.values(badges).filter(b=>b.unlocked).length;
  const totalPts=BADGE_DEFS.reduce((s,b)=>{const st=badges[b.id];return s+(st&&st.unlocked?b.points:0)},0);

  let html=`<h2 style="font-size:1.1rem;font-weight:800;margin-bottom:6px">${vendor} <span style="color:var(--accent);font-size:.85rem">${unlocked}/${BADGE_DEFS.length}</span></h2>
    <p style="font-size:.72rem;color:var(--yellow);margin-bottom:24px">Total badge points: ${totalPts}</p>`;

  const cats=[...new Set(BADGE_DEFS.map(b=>b.cat))];
  cats.forEach(cat=>{
    const catBadges=BADGE_DEFS.filter(b=>b.cat===cat);
    html+=`<div class="badges-section">
      <div class="badges-section-title">${cat} (${catBadges.filter(b=>badges[b.id]&&badges[b.id].unlocked).length}/${catBadges.length})</div>
      <div class="badge-grid">`;

    catBadges.forEach(b=>{
      const state=badges[b.id]||{unlocked:false};
      const isSecret=b.secret&&!state.unlocked;
      const lockedClass=state.unlocked?'unlocked':'locked';

      if(isSecret){
        html+=`<div class="badge-card locked secret-locked">
          <div class="badge-icon">???</div>
          <div class="badge-name">???</div>
          <div class="badge-desc">Secret badge</div>
          <div class="badge-pts">+${b.points} pts</div>
          <div class="badge-rarity r-${b.rarity}">${b.rarity}</div>
        </div>`;
      } else {
        const progress=state.unlocked?100:getProgress(b,vendor);
        html+=`<div class="badge-card ${lockedClass} rarity-${b.rarity}">
          <div class="badge-icon">${b.icon}</div>
          <div class="badge-name">${b.name}</div>
          <div class="badge-desc">${b.desc}</div>
          ${state.unlocked&&state.date?`<div class="badge-date">${new Date(state.date).toLocaleDateString('fr-FR')}</div>`:''}
          <div class="badge-pts">+${b.points} pts</div>
          <div class="badge-rarity r-${b.rarity}">${b.rarity}</div>
          ${!state.unlocked?`<div class="badge-progress"><div class="badge-progress-bar" style="width:${progress}%"></div></div>`:''}
        </div>`;
      }
    });

    html+=`</div></div>`;
  });

  return html;
}

function getProgress(badge,vendor){
  const vd=DATA.filter(d=>d.vendeur===vendor);
  const calls=CALL_HISTORY.filter(c=>c.vendor===vendor).length;
  const wins=vd.filter(d=>d.status==='valide').length;
  const rev=CLIENTS.filter(c=>c.vendor_name===vendor&&c.site_status!=='cancelled').reduce((s,c)=>s+(parseFloat(c.sale_price)||0),0);
  const pts=calcPoints(vendor);

  switch(badge.id){
    case 'first_dial':return Math.min(calls/1*100,100);
    case 'rookie':return Math.min(calls/3*100,100);
    case 'dialer':return Math.min(calls/10*100,100);
    case 'call_center':return Math.min(calls/25*100,100);
    case 'phone_warrior':return Math.min(calls/50*100,100);
    case 'century_caller':return Math.min(calls/100*100,100);
    case 'marathon_caller':return Math.min(calls/200*100,100);
    case 'legend_caller':return Math.min(calls/500*100,100);
    case 'first_sale':return Math.min(wins/1*100,100);
    case 'closer':return Math.min(wins/10*100,100);
    case 'elite_closer':return Math.min(wins/25*100,100);
    case 'master_closer':return Math.min(wins/50*100,100);
    case 'first_500':return Math.min(rev/500*100,100);
    case 'money_maker':return Math.min(rev/1000*100,100);
    case 'grand':return Math.min(rev/5000*100,100);
    case 'high_roller':return Math.min(rev/10000*100,100);
    case 'revenue_king':return Math.min(rev/25000*100,100);
    case 'bonus_hunter':return Math.min(pts/500*100,100);
    case 'double_bonus':return Math.min(pts/1000*100,100);
    case 'note_master':return Math.min(vd.filter(d=>d.notes).length/50*100,100);
    default:return 0;
  }
}

// ========================================
// 6. SCRIPTS TAB
// ========================================
function renderScripts(container){
  const myScripts=isAdmin?SCRIPTS:SCRIPTS.filter(s=>s.vendor===currentUser);

  let html=`<div class="scripts-wrap">
    <div class="scripts-header">
      <h2 style="font-size:1.1rem;font-weight:800">Mes Scripts <span style="color:var(--accent)">(${myScripts.length})</span></h2>
      <button class="btn btn-accent" onclick="openScriptModal()">+ Nouveau Script</button>
    </div>
    <div class="scripts-masonry">`;

  myScripts.forEach((s,i)=>{
    const color=POSTIT_COLORS[i%POSTIT_COLORS.length];
    html+=`<div class="postit" style="background:${color}">
      <div class="postit-title">${escHtml(s.title||'Sans titre')}</div>
      <div class="postit-content">${escHtml(s.content||'')}</div>
      <div class="postit-actions">
        <button onclick="openEditScriptModal(${s.id})" title="Modifier">&#9998;</button>
        <button onclick="confirmDeleteScript(${s.id})" title="Supprimer" style="color:var(--red)">&times;</button>
      </div>
    </div>`;
  });

  if(!myScripts.length){
    html+=`<div style="text-align:center;padding:40px;color:var(--gray)">Aucun script. Creez votre premier!</div>`;
  }

  html+=`</div></div>`;
  container.innerHTML=html;
}

function openScriptModal(existing){
  const colorOptions=POSTIT_COLORS.map((c,i)=>`<option value="${c}" style="background:${c}">Couleur ${i+1}</option>`).join('');
  openModal(`
    <h3>${existing?'Modifier':'Nouveau'} <span>Script</span></h3>
    <div class="modal-field"><label>Titre</label><input id="scriptTitle" value="${existing?escHtml(existing.title):''}"></div>
    <div class="modal-field"><label>Contenu</label><textarea id="scriptContent" style="min-height:150px">${existing?escHtml(existing.content):''}</textarea></div>
    <div class="modal-field"><label>Couleur</label><select id="scriptColor">${colorOptions}</select></div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeModal()">Annuler</button>
      <button class="btn btn-accent" onclick="${existing?`saveEditScript(${existing.id})`:'createScript()'}">${existing?'Sauvegarder':'Creer'}</button>
    </div>
  `);
}

async function createScript(){
  const title=document.getElementById('scriptTitle').value.trim();
  const content=document.getElementById('scriptContent').value.trim();
  const color=document.getElementById('scriptColor').value;
  if(!title){showToast('Erreur','Titre requis','var(--red)');return}
  const{data}=await sb.from('vendor_scripts').insert([{vendor:currentUser,title,content,color}]).select();
  if(data&&data[0])SCRIPTS.push(data[0]);
  closeModal();
  showToast('Script cree',title,'var(--green)');
  render();
}

function openEditScriptModal(id){
  const s=SCRIPTS.find(x=>x.id===id);
  if(s)openScriptModal(s);
}

async function saveEditScript(id){
  const obj={
    title:document.getElementById('scriptTitle').value.trim(),
    content:document.getElementById('scriptContent').value.trim(),
    color:document.getElementById('scriptColor').value
  };
  await sb.from('vendor_scripts').update(obj).eq('id',id);
  const s=SCRIPTS.find(x=>x.id===id);
  if(s)Object.assign(s,obj);
  closeModal();
  showToast('Script modifie','','var(--green)');
  render();
}

function confirmDeleteScript(id){
  showConfirmModal('Supprimer ce script ?',async()=>{
    await sb.from('vendor_scripts').delete().eq('id',id);
    SCRIPTS=SCRIPTS.filter(s=>s.id!==id);
    showToast('Script supprime','','var(--red)');
    render();
  });
}

// ========================================
// 7. REMINDERS TAB
// ========================================
function renderReminders(container){
  const myReminders=isAdmin?REMINDERS:REMINDERS.filter(r=>r.vendor===currentUser);
  const now=new Date();

  const sorted=[...myReminders].sort((a,b)=>new Date(a.remind_at)-new Date(b.remind_at));

  let html=`<div class="reminders-wrap">
    <h2 style="font-size:1.1rem;font-weight:800;margin-bottom:20px">Rappels <span style="color:var(--accent)">(${sorted.length})</span></h2>`;

  if(!sorted.length){
    html+=`<div style="text-align:center;padding:40px;color:var(--gray)">Aucun rappel programme.</div>`;
  }

  sorted.forEach(r=>{
    const remDate=new Date(r.remind_at);
    const overdue=remDate<now&&r.status!=='done';
    html+=`<div class="reminder-card${overdue?' overdue':''}">
      <div style="flex:1">
        <div style="font-size:.82rem;font-weight:700">${escHtml(r.prospect_name||'Prospect')}</div>
        <div style="font-size:.68rem;color:var(--gray)">${remDate.toLocaleString('fr-FR')}${overdue?' - <span style="color:var(--red);font-weight:700">EN RETARD</span>':''}</div>
        ${r.notes?`<div style="font-size:.68rem;color:var(--gray);margin-top:4px;font-style:italic">${escHtml(r.notes)}</div>`:''}
      </div>
      <div style="display:flex;gap:6px">
        ${r.prospect_id?`<button class="btn btn-accent btn-sm" onclick="startCall(${r.prospect_id})">&#128222; Appeler</button>`:''}
        <button class="btn btn-ghost btn-sm" onclick="dismissReminder(${r.id})">Fermer</button>
      </div>
    </div>`;
  });

  html+=`</div>`;
  container.innerHTML=html;
}

async function dismissReminder(id){
  await sb.from('reminders').update({status:'done'}).eq('id',id);
  REMINDERS=REMINDERS.filter(r=>r.id!==id);
  showToast('Rappel ferme','','var(--accent)');
  render();
}

// ========================================
// 8. CLIENTS TAB
// ========================================
function renderClients(container){
  const myClients=isAdmin?CLIENTS:CLIENTS.filter(c=>c.vendor_name===currentUser);

  let html=`<div class="clients-wrap">
    <div class="clients-header">
      <h2 style="font-size:1.1rem;font-weight:800">Clients <span style="color:var(--accent)">(${myClients.length})</span></h2>
      ${isAdmin?`<button class="btn btn-accent" onclick="openAddClientModal()">+ Ajouter Client</button>`:''}
    </div>
    <div class="clients-grid">`;

  if(!myClients.length){
    html+=`<div style="grid-column:1/-1;text-align:center;padding:60px;color:var(--gray)"><p style="font-size:1.2rem;margin-bottom:8px">Aucun client</p><p style="font-size:.78rem">Les clients sont crees automatiquement quand un prospect passe en "valide".</p></div>`;
  }

  myClients.forEach(c=>{
    const soldDate=c.sold_at||c.sale_date;
    const daysSince=soldDate?Math.floor((Date.now()-new Date(soldDate))/(1000*60*60*24)):0;
    const statusLabel=SITE_STATUS_LABELS[c.site_status]||c.site_status||'Not started';
    const statusClass=c.site_status||'not_started';
    const statusOptions=SITE_STATUSES.map(s=>`<option value="${s}"${c.site_status===s?' selected':''}>${SITE_STATUS_LABELS[s]}</option>`).join('');

    html+=`<div class="client-card status-${statusClass}">
      <div class="client-card-name">${escHtml(c.business_name||'')}</div>
      <div class="client-card-phone"><a href="tel:${c.phone}">${c.phone||''}</a></div>
      <div class="client-card-meta">
        <span style="display:inline-block;padding:2px 8px;border-radius:8px;font-size:.58rem;font-weight:600;background:rgba(88,166,255,.1);color:var(--accent)">${escHtml(c.vendor_name||'')}</span>
        &middot; ${daysSince}j depuis vente
        ${c.sale_price?` &middot; <span style="color:var(--green)">${c.sale_price}&#8364;</span>`:''}
      </div>
      <div style="margin-bottom:10px"><span class="site-status-badge ss-${statusClass}">${statusLabel}</span></div>
      <div style="margin-bottom:8px">
        <select class="tsel" style="width:100%" onchange="updateClientStatus(${c.id},this.value)">${statusOptions}</select>
      </div>
      <div style="margin-bottom:8px">
        <textarea class="ninp" style="min-height:40px;resize:vertical" onblur="updateClientNotes(${c.id},this.value)" placeholder="Notes de livraison...">${escHtml(c.delivery_notes||'')}</textarea>
      </div>
      <div style="display:flex;gap:6px;flex-wrap:wrap">
        <button class="btn btn-ghost btn-sm" onclick="openEditClientModal(${c.id})">Modifier</button>
        <button class="btn btn-ghost btn-sm" onclick="addClientNote(${c.id})">+ Note</button>
        ${isAdmin?`<button class="btn btn-ghost btn-sm" style="color:var(--red);border-color:var(--red)" onclick="confirmDeleteClient(${c.id})">Supprimer</button>`:''}
      </div>
    </div>`;
  });

  html+=`</div></div>`;
  container.innerHTML=html;
}

function openAddClientModal(){
  openModal(`
    <h3>Ajouter <span>Client</span></h3>
    <div class="modal-field"><label>Nom entreprise</label><input id="newClientName"></div>
    <div class="modal-field"><label>Telephone</label><input id="newClientPhone"></div>
    <div class="modal-field"><label>Vendeur</label><select id="newClientVendor">${VENDOR_NAMES.map(v=>`<option value="${v}">${v}</option>`).join('')}</select></div>
    <div class="modal-field"><label>Prix de vente (EUR)</label><input id="newClientPrice" type="number" value="500"></div>
    <div class="modal-field"><label>Notes</label><textarea id="newClientNotes"></textarea></div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeModal()">Annuler</button>
      <button class="btn btn-accent" onclick="addClient()">Ajouter</button>
    </div>
  `);
}

async function addClient(){
  const obj={
    business_name:document.getElementById('newClientName').value.trim(),
    phone:document.getElementById('newClientPhone').value.trim(),
    vendor_name:document.getElementById('newClientVendor').value,
    sale_price:parseInt(document.getElementById('newClientPrice').value)||500,
    delivery_notes:document.getElementById('newClientNotes').value.trim(),
    sold_at:new Date().toISOString(),
    site_status:'not_started'
  };
  const{data}=await sb.from('clients').insert([obj]).select();
  if(data&&data[0])CLIENTS.push(data[0]);
  closeModal();
  await logActivity('client_created',obj.business_name,null,'Manual add');
  showToast('Client ajoute',obj.business_name,'var(--green)');
  render();
}

function openEditClientModal(id){
  const c=CLIENTS.find(x=>x.id===id);
  if(!c)return;
  openModal(`
    <h3>Modifier <span>Client</span></h3>
    <div class="modal-field"><label>Nom entreprise</label><input id="editClientName" value="${escHtml(c.business_name||'')}"></div>
    <div class="modal-field"><label>Telephone</label><input id="editClientPhone" value="${escHtml(c.phone||'')}"></div>
    <div class="modal-field"><label>Vendeur</label><select id="editClientVendor">${VENDOR_NAMES.map(v=>`<option value="${v}"${c.vendor_name===v?' selected':''}>${v}</option>`).join('')}</select></div>
    <div class="modal-field"><label>Prix de vente (EUR)</label><input id="editClientPrice" type="number" value="${c.sale_price||500}"></div>
    <div class="modal-field"><label>Status du site</label><select id="editClientSiteStatus">${SITE_STATUSES.map(s=>`<option value="${s}"${c.site_status===s?' selected':''}>${SITE_STATUS_LABELS[s]}</option>`).join('')}</select></div>
    <div class="modal-field"><label>Notes de livraison</label><textarea id="editClientDeliveryNotes">${escHtml(c.delivery_notes||'')}</textarea></div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeModal()">Annuler</button>
      <button class="btn btn-accent" onclick="saveEditClient(${id})">Sauvegarder</button>
    </div>
  `);
}

async function saveEditClient(id){
  const obj={
    business_name:document.getElementById('editClientName').value.trim(),
    phone:document.getElementById('editClientPhone').value.trim(),
    vendor_name:document.getElementById('editClientVendor').value,
    sale_price:parseInt(document.getElementById('editClientPrice').value)||500,
    site_status:document.getElementById('editClientSiteStatus').value,
    delivery_notes:document.getElementById('editClientDeliveryNotes').value.trim(),
    updated_at:new Date().toISOString()
  };
  await sb.from('clients').update(obj).eq('id',id);
  const c=CLIENTS.find(x=>x.id===id);
  if(c)Object.assign(c,obj);
  closeModal();
  showToast('Client modifie','','var(--green)');
  render();
}

function confirmDeleteClient(id){
  showConfirmModal('Supprimer ce client ?',async()=>{
    await sb.from('clients').delete().eq('id',id);
    CLIENTS=CLIENTS.filter(c=>c.id!==id);
    showToast('Client supprime','','var(--red)');
    render();
  });
}

async function updateClientStatus(id,status){
  await sb.from('clients').update({site_status:status,updated_at:new Date().toISOString()}).eq('id',id);
  const c=CLIENTS.find(x=>x.id===id);if(c)c.site_status=status;
  await logActivity('client_status_update','',null,'Client #'+id+' -> '+status);
  render();
}

async function updateClientNotes(id,notes){
  await sb.from('clients').update({delivery_notes:notes,updated_at:new Date().toISOString()}).eq('id',id);
  const c=CLIENTS.find(x=>x.id===id);if(c)c.delivery_notes=notes;
}

function addClientNote(id){
  const note=prompt('Ajouter une note:');
  if(note){
    const c=CLIENTS.find(x=>x.id===id);
    if(c){
      const existing=c.delivery_notes||'';
      const updated=existing+(existing?'\n':'')+new Date().toLocaleDateString('fr-FR')+': '+note;
      updateClientNotes(id,updated);
      showToast('Note ajoutee','','var(--green)');
      render();
    }
  }
}

// ========================================
// 9. VENDORS TAB (Admin)
// ========================================
function renderVendors(container){
  let html=`<div class="vendor-grid">`;

  VENDOR_NAMES.forEach(v=>{
    const stats=getVendorStats(v);
    const pts=calcPoints(v);
    const badges=getBadges(v);
    const unlockedCount=Object.values(badges).filter(b=>b.unlocked).length;
    const revenue=stats.rev;
    const forecast=stats.nego*150;

    html+=`<div class="vendor-card">
      <h3>${v}</h3>
      <div class="vendor-stat-row"><span class="vendor-stat-lbl">Points</span><span class="vendor-stat-val" style="color:var(--yellow)">${pts}</span></div>
      <div class="vendor-stat-row"><span class="vendor-stat-lbl">Appels</span><span class="vendor-stat-val" style="color:var(--accent)">${stats.calls}</span></div>
      <div class="vendor-stat-row"><span class="vendor-stat-lbl">Gagnes</span><span class="vendor-stat-val" style="color:var(--green)">${stats.wins}</span></div>
      <div class="vendor-stat-row"><span class="vendor-stat-lbl">Perdus</span><span class="vendor-stat-val" style="color:var(--red)">${stats.lost}</span></div>
      <div class="vendor-stat-row"><span class="vendor-stat-lbl">Negociation</span><span class="vendor-stat-val" style="color:var(--orange)">${stats.nego}</span></div>
      <div class="vendor-stat-row"><span class="vendor-stat-lbl">Conversion</span><span class="vendor-stat-val" style="color:var(--purple)">${stats.conv}%</span></div>
      <div class="vendor-stat-row"><span class="vendor-stat-lbl">Revenue</span><span class="vendor-stat-val" style="color:var(--green)">${revenue.toLocaleString()}&#8364;</span></div>
      <div class="vendor-stat-row"><span class="vendor-stat-lbl">Forecast (nego*150)</span><span class="vendor-stat-val" style="color:var(--yellow)">${forecast.toLocaleString()}&#8364;</span></div>
      <div class="vendor-stat-row"><span class="vendor-stat-lbl">Badges</span><span class="vendor-stat-val" style="color:var(--accent)">${unlockedCount}/${BADGE_DEFS.length}</span></div>
    </div>`;
  });

  html+=`</div>`;

  // Chart
  html+=`<div class="chart-wrap"><div class="chart-box"><canvas id="vendorChart" height="300"></canvas></div></div>`;

  container.innerHTML=html;

  // Render chart
  setTimeout(()=>{
    const ctx=document.getElementById('vendorChart');
    if(!ctx)return;
    const labels=VENDOR_NAMES;
    const winsData=labels.map(v=>getVendorStats(v).wins);
    const callsData=labels.map(v=>getVendorStats(v).calls);
    const negoData=labels.map(v=>getVendorStats(v).nego);

    new Chart(ctx,{
      type:'bar',
      data:{
        labels,
        datasets:[
          {label:'Appels',data:callsData,backgroundColor:'rgba(88,166,255,.6)'},
          {label:'Gagnes',data:winsData,backgroundColor:'rgba(63,185,80,.6)'},
          {label:'Negociation',data:negoData,backgroundColor:'rgba(219,109,40,.6)'}
        ]
      },
      options:{
        responsive:true,
        plugins:{legend:{labels:{color:'#e6edf3',font:{family:'Inter'}}}},
        scales:{
          x:{ticks:{color:'#8b949e'},grid:{color:'rgba(48,54,61,.5)'}},
          y:{ticks:{color:'#8b949e'},grid:{color:'rgba(48,54,61,.5)'}}
        }
      }
    });
  },100);
}

// ========================================
// 10. LOGS TAB (Admin)
// ========================================
async function renderLogs(container){
  const{data}=await sb.from('activity_log').select('*').order('created_at',{ascending:false}).limit(200);
  LOGS=data||[];

  let html=`<div class="logs-wrap">
    <h2 style="font-size:1.1rem;font-weight:800;margin-bottom:16px">Activity Logs <span style="color:var(--accent)">(${LOGS.length})</span></h2>
    <div style="display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap">
      <input class="search" id="logSearch" placeholder="Rechercher..." oninput="filterLogs()">
      <select class="flt" id="logVendorFilter" onchange="filterLogs()"><option value="">Tous vendeurs</option>${VENDOR_NAMES.map(v=>`<option value="${v}">${v}</option>`).join('')}<option value="Admin">Admin</option></select>
    </div>
    <table class="log-table"><thead><tr>
      <th>Date</th><th>Vendeur</th><th>Action</th><th>Cible</th><th>Details</th>
    </tr></thead><tbody id="logTableBody">`;

  LOGS.forEach(l=>{
    html+=`<tr data-vendor="${escHtml(l.vendor||'')}" data-action="${escHtml(l.action||'')}">
      <td style="white-space:nowrap">${new Date(l.created_at).toLocaleString('fr-FR')}</td>
      <td>${escHtml(l.vendor||'')}</td>
      <td><span class="badge" style="background:rgba(88,166,255,.1);color:var(--accent)">${escHtml(l.action||'')}</span></td>
      <td>${escHtml(l.target_name||'')}</td>
      <td style="color:var(--gray)">${escHtml(l.details||'')}</td>
    </tr>`;
  });

  html+=`</tbody></table></div>`;
  container.innerHTML=html;
}

function filterLogs(){
  const search=(document.getElementById('logSearch').value||'').toLowerCase();
  const vendor=document.getElementById('logVendorFilter').value;
  document.querySelectorAll('#logTableBody tr').forEach(tr=>{
    const vendorMatch=!vendor||tr.dataset.vendor===vendor;
    const searchMatch=!search||tr.textContent.toLowerCase().includes(search);
    tr.style.display=vendorMatch&&searchMatch?'':'none';
  });
}

// ========================================
// 11. BLACKLIST TAB (Admin)
// ========================================
function renderBlacklist(container){
  let html=`<div class="blacklist-wrap">
    <h2 style="font-size:1.1rem;font-weight:800;margin-bottom:20px">Blacklist <span style="color:var(--red)">(${BLACKLIST.length})</span></h2>`;

  if(!BLACKLIST.length){
    html+=`<div style="text-align:center;padding:40px;color:var(--gray)">Aucun prospect blackliste.</div>`;
  }

  BLACKLIST.forEach(b=>{
    html+=`<div class="bl-card">
      <div>
        <div style="font-size:.82rem;font-weight:700">${escHtml(b.prospect_name||'Prospect #'+b.prospect_id)}</div>
        <div style="font-size:.68rem;color:var(--gray)">${b.reason||''} &middot; ${new Date(b.created_at).toLocaleDateString('fr-FR')}</div>
      </div>
      <button class="btn btn-green btn-sm" onclick="restoreFromBlacklist(${b.id},${b.prospect_id})">Restaurer</button>
    </div>`;
  });

  html+=`</div>`;
  container.innerHTML=html;
}

async function restoreFromBlacklist(blId,prospectId){
  await sb.from('blacklist').delete().eq('id',blId);
  await sb.from('prospects').update({blacklisted:false}).eq('id',prospectId);
  BLACKLIST=BLACKLIST.filter(b=>b.id!==blId);
  await logActivity('restore_blacklist','',prospectId,'Restored');
  showToast('Prospect restaure','','var(--green)');
  await loadData();
  render();
}

// ========================================
// FIELD UPDATE
// ========================================
async function updateField(id,field,value){
  const obj={[field]:value,updated_at:new Date().toISOString()};
  const row=DATA.find(d=>d.id===id);
  const oldStatus=row?row.status:'';

  await sb.from('prospects').update(obj).eq('id',id);
  if(row)Object.keys(obj).forEach(k=>{row[k]=obj[k]});

  if(field==='status'){
    await logActivity('status_change',row?row.nom:'',id,oldStatus+' -> '+value);
  }
  if(field==='vendeur'){
    await logActivity('vendor_assign',row?row.nom:'',id,'-> '+value);
  }

  // Auto-create client when status becomes "valide"
  if(field==='status'&&value==='valide'&&row){
    const alreadyClient=CLIENTS.find(c=>c.prospect_id===id);
    if(!alreadyClient){
      const clientData={
        prospect_id:id,
        business_name:row.nom||'',
        phone:row.numero||'',
        vendor_name:row.vendeur||currentUser,
        sold_at:new Date().toISOString(),
        site_status:'not_started',
        sale_price:500,
        with_maintenance:false
      };
      const{data}=await sb.from('clients').insert([clientData]).select();
      if(data&&data[0])CLIENTS.push(data[0]);
      showToast('Nouveau client!',row.nom+' ajoute aux clients.','var(--green)');
    }
  }

  // If rappeler, prompt for reminder
  if(field==='status'&&value==='rappeler'&&row){
    setTimeout(()=>showReminderPicker(id,row.nom||''),300);
  }

  render();
}

// ========================================
// BLACKLIST
// ========================================
function blacklistProspect(id){
  showConfirmModal('Blacklister ce prospect ?',async()=>{
    const row=DATA.find(d=>d.id===id);
    await sb.from('prospects').update({blacklisted:true}).eq('id',id);
    await sb.from('blacklist').insert([{
      prospect_id:id,
      prospect_name:row?row.nom:'',
      reason:'Manual blacklist by '+currentUser,
      created_at:new Date().toISOString()
    }]);
    DATA=DATA.filter(d=>d.id!==id);
    const{data:blData}=await sb.from('blacklist').select('*').order('id');
    BLACKLIST=blData||[];
    await logActivity('blacklist',row?row.nom:'',id,'Blacklisted');
    showToast('Prospect blackliste','','var(--red)');
    render();
  });
}

// ========================================
// CALL TIMER
// ========================================
function startCall(id){
  const row=DATA.find(d=>d.id===id);
  if(!row)return;

  if(callTimerInterval){
    showToast('Appel en cours','Terminez l\'appel en cours d\'abord.','var(--yellow)');
    return;
  }

  callProspect=row;
  callStartTime=Date.now();

  // Update last_called_at
  sb.from('prospects').update({last_called_at:new Date().toISOString(),total_calls:(row.total_calls||0)+1}).eq('id',id);
  row.total_calls=(row.total_calls||0)+1;
  row.last_called_at=new Date().toISOString();

  // Show call bar
  const bar=document.createElement('div');
  bar.className='call-timer-bar';
  bar.id='callTimerBar';
  bar.innerHTML=`
    <div style="display:flex;align-items:center;gap:12px">
      <div class="call-timer-pulse"></div>
      <div class="call-timer-name">${escHtml(row.nom)}</div>
      <a href="tel:${row.numero}" style="font-size:.72rem">${row.numero}</a>
    </div>
    <div class="call-timer-display" id="callTimerDisplay">00:00:00</div>
    <button class="btn btn-red" onclick="endCall()">Terminer l'appel</button>
  `;
  document.body.appendChild(bar);

  callTimerInterval=setInterval(()=>{
    const elapsed=Math.floor((Date.now()-callStartTime)/1000);
    const h=String(Math.floor(elapsed/3600)).padStart(2,'0');
    const m=String(Math.floor((elapsed%3600)/60)).padStart(2,'0');
    const s=String(elapsed%60).padStart(2,'0');
    const display=document.getElementById('callTimerDisplay');
    if(display)display.textContent=h+':'+m+':'+s;
  },1000);

  logActivity('call_started',row.nom,id,'');
}

function endCall(){
  if(!callTimerInterval)return;
  clearInterval(callTimerInterval);
  callTimerInterval=null;

  const elapsed=Math.floor((Date.now()-callStartTime)/1000);
  const bar=document.getElementById('callTimerBar');
  if(bar)bar.remove();

  // Show result modal
  openModal(`
    <h3>Resultat de <span>l'appel</span></h3>
    <p style="font-size:.82rem;margin-bottom:16px">${escHtml(callProspect.nom)} - Duree: ${formatDuration(elapsed)}</p>
    <div class="modal-field"><label>Resultat</label>
      <select id="callResult">
        <option value="interested">Interesse</option>
        <option value="not-interested">Pas interesse</option>
        <option value="callback">Rappeler</option>
        <option value="no-answer">Pas de reponse</option>
      </select>
    </div>
    <div class="modal-field"><label>Notes</label><textarea id="callNotes" placeholder="Notes de l'appel..."></textarea></div>
    <div id="callbackDateWrap" style="display:none">
      <div class="modal-field"><label>Date de rappel</label><input type="datetime-local" id="callbackDate"></div>
    </div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeModal()">Annuler</button>
      <button class="btn btn-accent" onclick="saveCallResult(${callProspect.id},${elapsed})">Sauvegarder</button>
    </div>
    <scr`+`ipt>document.getElementById('callResult').addEventListener('change',function(){document.getElementById('callbackDateWrap').style.display=this.value==='callback'?'block':'none'});</scr`+`ipt>
  `);
}

function formatDuration(seconds){
  const h=Math.floor(seconds/3600);
  const m=Math.floor((seconds%3600)/60);
  const s=seconds%60;
  return(h?h+'h ':'')+(m?m+'m ':'')+s+'s';
}

async function saveCallResult(prospectId,duration){
  const result=document.getElementById('callResult').value;
  const notes=document.getElementById('callNotes').value.trim();

  // Save to call_history
  const entry={
    prospect_id:prospectId,
    prospect_name:callProspect.nom,
    vendor:currentUser,
    result,
    notes,
    duration,
    created_at:new Date().toISOString()
  };
  const{data}=await sb.from('call_history').insert([entry]).select();
  if(data&&data[0])CALL_HISTORY.unshift(data[0]);

  // Update streak
  await updateStreak(currentUser);

  // Update prospect call_duration_total
  const row=DATA.find(d=>d.id===prospectId);
  if(row){
    const newDuration=(row.call_duration_total||0)+duration;
    await sb.from('prospects').update({call_duration_total:newDuration,call_date:new Date().toISOString()}).eq('id',prospectId);
    row.call_duration_total=newDuration;
    row.call_date=new Date().toISOString();
  }

  // Auto-status update based on result
  if(result==='interested'){
    await updateField(prospectId,'status','negociation');
  } else if(result==='not-interested'){
    await updateField(prospectId,'status','perdu');
  } else if(result==='callback'){
    await updateField(prospectId,'status','rappeler');
    const callbackDate=document.getElementById('callbackDate').value;
    if(callbackDate){
      await sb.from('reminders').insert([{
        prospect_id:prospectId,
        prospect_name:callProspect.nom,
        vendor:currentUser,
        remind_at:new Date(callbackDate).toISOString(),
        notes,
        status:'pending'
      }]);
      const{data:remData}=await sb.from('reminders').select('*').order('remind_at');
      REMINDERS=remData||[];
    }
  } else {
    // no-answer: set to appele if still nouveau
    if(row&&row.status==='nouveau'){
      await updateField(prospectId,'status','appelle');
    }
  }

  await logActivity('call_completed',callProspect.nom,prospectId,result+' ('+formatDuration(duration)+')');

  closeModal();
  callProspect=null;
  showToast('Appel enregistre','','var(--green)');
  render();
}

