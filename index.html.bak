        <label style="font-size:.72rem;display:flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" class="obj-check" value="win_10_sales"> Win 10 sales in region</label>
        <label style="font-size:.72rem;display:flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" class="obj-check" value="gen_2500"> Generate 2500&#8364; from region</label>
        <label style="font-size:.72rem;display:flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" class="obj-check" value="gen_5000"> Generate 5000&#8364; from region</label>
        <label style="font-size:.72rem;display:flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" class="obj-check" value="call_50_pct"> Call 50% of prospects in 1 week</label>
        <label style="font-size:.72rem;display:flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" class="obj-check" value="call_100_in_3d"> Call 100 prospects in 3 days</label>
        <label style="font-size:.72rem;display:flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" class="obj-check" value="get_20_interested"> Get 20 interested clients</label>
        <label style="font-size:.72rem;display:flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" class="obj-check" value="zero_losses"> Zero losses - win 5 with 0 lost</label>
      </div>
      <div style="margin-top:8px">
        <div id="customObjList"></div>
        <div style="display:flex;gap:6px;margin-top:6px"><input class="search" id="customObjInput" placeholder="Add custom objective..." style="flex:1;width:auto"><button class="btn btn-ghost btn-sm" onclick="addCustomObj()">+ Add</button></div>
      </div>
    </div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeModal()">Annuler</button>
      <button class="btn btn-accent" onclick="createProject()">Creer</button>
    </div>
  `);
}

async function createProject(){
  const name=document.getElementById('projName').value.trim();
  const region=document.getElementById('projRegion').value;
  const vendeur=document.getElementById('projVendeur').value;
  const startDate=document.getElementById('projStartDate').value||null;
  const desc=document.getElementById('projDesc').value.trim()||null;
  if(!name){showToast('Erreur','Nom requis','var(--red)');return}
  if(!region){showToast('Erreur','Region requise','var(--red)');return}
  const insertData={name,region,vendeur,status:'active',description:desc};
  if(startDate)insertData.created_at=new Date(startDate).toISOString();
  const{data:insData}=await sb.from('projects').insert([insertData]).select();
  if(insData&&insData[0]){
    await saveProjectObjectives(insData[0].id);
  }
  closeModal();
  await loadData();
  showToast('Projet cree',name+' - '+region,'var(--green)');
  render();
}

