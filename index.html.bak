async function openDetail(id){
  const row=DATA.find(d=>d.id===id);
  if(!row)return;

  // Fetch call history for this prospect
  const{data:history}=await sb.from('call_history').select('*').eq('prospect_id',id).order('created_at',{ascending:false}).limit(20);

  const panel=document.getElementById('detailContent');
  let html=`
    <h2 style="font-size:1.2rem;font-weight:800;margin-bottom:4px">${escHtml(row.nom)}</h2>
    <p style="font-size:.78rem;color:var(--accent);margin-bottom:20px"><a href="tel:${row.numero}">${row.numero||''}</a></p>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:20px">
      <div style="background:var(--s2);padding:10px;border-radius:8px"><div style="font-size:.55rem;color:var(--gray);text-transform:uppercase;letter-spacing:.1em">Type</div><div style="font-size:.78rem;font-weight:600">${row.type_tel||'--'}</div></div>
      <div style="background:var(--s2);padding:10px;border-radius:8px"><div style="font-size:.55rem;color:var(--gray);text-transform:uppercase;letter-spacing:.1em">Famille</div><div style="font-size:.78rem;font-weight:600">${row.famille||'--'}</div></div>
      <div style="background:var(--s2);padding:10px;border-radius:8px"><div style="font-size:.55rem;color:var(--gray);text-transform:uppercase;letter-spacing:.1em">Categorie</div><div style="font-size:.78rem;font-weight:600">${row.categorie||'--'}</div></div>
      <div style="background:var(--s2);padding:10px;border-radius:8px"><div style="font-size:.55rem;color:var(--gray);text-transform:uppercase;letter-spacing:.1em">Region</div><div style="font-size:.78rem;font-weight:600;color:var(--yellow)">${row.region||'--'}</div></div>
      <div style="background:var(--s2);padding:10px;border-radius:8px"><div style="font-size:.55rem;color:var(--gray);text-transform:uppercase;letter-spacing:.1em">Vendeur</div><div style="font-size:.78rem;font-weight:600">${row.vendeur||'--'}</div></div>
      <div style="background:var(--s2);padding:10px;border-radius:8px"><div style="font-size:.55rem;color:var(--gray);text-transform:uppercase;letter-spacing:.1em">Status</div><div style="font-size:.78rem;font-weight:600" style="color:${STATUS_COLORS[row.status]}">${STATUS_LABELS[row.status]||row.status}</div></div>
      <div style="background:var(--s2);padding:10px;border-radius:8px;grid-column:span 2"><div style="font-size:.55rem;color:var(--gray);text-transform:uppercase;letter-spacing:.1em">Adresse</div><div style="font-size:.72rem">${escHtml(row.adresse||'--')}</div></div>
    </div>

    <div style="margin-bottom:16px">
      <div style="font-size:.65rem;color:var(--gray);text-transform:uppercase;letter-spacing:.1em;margin-bottom:6px">Appels: ${row.total_calls||0} | Duree totale: ${formatDuration(row.call_duration_total||0)}</div>
    </div>

    <div style="display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap">
      <button class="btn btn-accent btn-sm" onclick="startCall(${id});closeDetail()">&#128222; Appeler</button>
      <button class="btn btn-ghost btn-sm" onclick="showReminderPicker(${id},'${esc(row.nom)}')">&#128276; Rappel</button>
    </div>

    <!-- CALL SCRIPT -->
    <div style="margin-bottom:20px">
      <h3 style="font-size:.82rem;font-weight:700;margin-bottom:10px">Script d'appel</h3>
      <div style="background:var(--s2);padding:14px;border-radius:8px;margin-bottom:8px">
        <div style="font-size:.6rem;color:var(--gray);margin-bottom:4px">&#127468;&#127479; GREC</div>
        <div style="font-size:.72rem;line-height:1.6">${CALL_SCRIPT_GR.replace('[name]','<strong style="color:var(--accent)">'+currentUser+'</strong>')}</div>
      </div>
      <div style="background:var(--s2);padding:14px;border-radius:8px">
        <div style="font-size:.6rem;color:var(--gray);margin-bottom:4px">&#127468;&#127463; ENGLISH</div>
        <div style="font-size:.72rem;line-height:1.6">${CALL_SCRIPT_EN.replace('[name]','<strong style="color:var(--accent)">'+currentUser+'</strong>')}</div>
      </div>
    </div>

    <!-- OBJECTION HANDLERS -->
    <div style="margin-bottom:20px">
      <h3 style="font-size:.82rem;font-weight:700;margin-bottom:10px">Reponses aux objections</h3>
      ${Object.keys(OBJECTIONS).map(k=>{
        const o=OBJECTIONS[k];
        return`<button class="btn btn-ghost btn-sm" style="margin-bottom:6px;display:block;width:100%;text-align:left" onclick="this.nextElementSibling.style.display=this.nextElementSibling.style.display==='none'?'block':'none'">${o.label}</button>
        <div style="display:none;background:var(--s2);padding:12px;border-radius:8px;margin-bottom:8px">
          <div style="font-size:.65rem;color:var(--gray);margin-bottom:4px">&#127468;&#127479; ${o.gr}</div>
          <div style="font-size:.65rem;color:var(--gray)">&#127468;&#127463; ${o.en}</div>
        </div>`;
      }).join('')}
    </div>

    <!-- NOTES -->
    <div style="margin-bottom:20px">
      <h3 style="font-size:.82rem;font-weight:700;margin-bottom:10px">Notes</h3>
      <textarea class="ninp" style="min-height:80px;resize:vertical" onblur="updateField(${id},'notes',this.value)">${escHtml(row.notes||'')}</textarea>
    </div>

    <!-- CALL HISTORY -->
    <div>
      <h3 style="font-size:.82rem;font-weight:700;margin-bottom:10px">Historique d'appels (${(history||[]).length})</h3>`;

  if(history&&history.length){
    history.forEach(h=>{
      html+=`<div class="call-entry">
        <div class="call-entry-head">
          <span class="call-entry-date">${new Date(h.created_at).toLocaleString('fr-FR')}</span>
          <span class="call-entry-result ${h.result}">${h.result}</span>
        </div>
        <div class="call-entry-info">${h.vendor||''} &middot; ${formatDuration(h.duration||0)}</div>
        ${h.notes?`<div class="call-entry-notes">${escHtml(h.notes)}</div>`:''}
      </div>`;
    });
  } else {
    html+=`<div style="font-size:.72rem;color:var(--gray)">Aucun appel enregistre.</div>`;
  }

  html+=`</div>`;
  panel.innerHTML=html;

  document.getElementById('detailPanel').classList.add('open');
  document.getElementById('detailPanelBackdrop').classList.add('open');
  gsap.fromTo('#detailPanel',{x:420},{x:0,duration:.3,ease:'power2.out'});
}

function closeDetail(){
  document.getElementById('detailPanel').classList.remove('open');
  document.getElementById('detailPanelBackdrop').classList.remove('open');
}

// ========================================
// POINTS SYSTEM
// ========================================
function calcPoints(vendor){
  const vd=DATA.filter(d=>d.vendeur===vendor);
  let pts=0;
  pts+=vd.filter(d=>d.status==='appelle').length*1;
  pts+=vd.filter(d=>d.status==='negociation').length*20;
  pts+=vd.filter(d=>d.status==='valide').length*100;
  pts+=vd.filter(d=>d.status==='rappeler').length*5;
  pts+=CALL_HISTORY.filter(c=>c.vendor===vendor).length*2;
  // Badge points
  const badges=getBadges(vendor);
  pts+=BADGE_DEFS.reduce((s,b)=>{const st=badges[b.id];return s+(st&&st.unlocked?b.points:0)},0);
  return pts;
}

function getVendorStats(vendor){
  const vd=DATA.filter(d=>d.vendeur===vendor);
  const calls=CALL_HISTORY.filter(c=>c.vendor===vendor).length;
  const wins=vd.filter(d=>d.status==='valide').length;
  const lost=vd.filter(d=>d.status==='perdu').length;
  const nego=vd.filter(d=>d.status==='negociation').length;
  const conv=wins+lost>0?((wins/(wins+lost))*100).toFixed(1):'0';
  const rev=CLIENTS.filter(c=>c.vendor_name===vendor&&c.site_status!=='cancelled').reduce((s,c)=>s+(parseFloat(c.sale_price)||0),0);
  return{calls,wins,lost,nego,conv,rev};
}

// ========================================
// BADGES
// ========================================
let BADGES_CACHE={};
async function loadAllBadges(){
  const{data}=await sb.from('vendor_badges').select('*');
  BADGES_CACHE={};
  (data||[]).forEach(b=>{
    if(!BADGES_CACHE[b.vendor_name])BADGES_CACHE[b.vendor_name]={};
    BADGES_CACHE[b.vendor_name][b.badge_id]={unlocked:true,date:b.unlocked_at};
  });
}
function getBadges(vendor){
  const init={};
  BADGE_DEFS.forEach(b=>{init[b.id]={unlocked:false,date:null}});
  return{...init,...(BADGES_CACHE[vendor]||{})};
}

async function unlockBadge(vendor,badgeId){
  const badges=getBadges(vendor);
  if(badges[badgeId]&&badges[badgeId].unlocked)return false;
  await sb.from('vendor_badges').upsert({vendor_name:vendor,badge_id:badgeId,unlocked_at:new Date().toISOString()},{onConflict:'vendor_name,badge_id'});
  if(!BADGES_CACHE[vendor])BADGES_CACHE[vendor]={};
  BADGES_CACHE[vendor][badgeId]={unlocked:true,date:new Date().toISOString()};
  const def=BADGE_DEFS.find(b=>b.id===badgeId);
  if(def&&vendor===currentUser){
    showBadgeUnlock(def);
  }
  return true;
}

// ====== VENDOR STATS (STREAKS) ======
let VENDOR_STATS_CACHE={};
async function loadVendorStats(){
  const{data}=await sb.from('vendor_stats').select('*');
  VENDOR_STATS_CACHE={};
  (data||[]).forEach(s=>{VENDOR_STATS_CACHE[s.vendor_name]=s});
}

async function updateStreak(vendor){
  const today=new Date().toISOString().slice(0,10);
  let stats=VENDOR_STATS_CACHE[vendor];
  if(!stats){
    stats={vendor_name:vendor,current_streak:1,longest_streak:1,last_call_date:today,total_points:0};
    await sb.from('vendor_stats').upsert(stats,{onConflict:'vendor_name'});
    VENDOR_STATS_CACHE[vendor]=stats;
    return;
  }
  if(stats.last_call_date===today)return;
  const yesterday=new Date(Date.now()-86400000).toISOString().slice(0,10);
  if(stats.last_call_date===yesterday){
    stats.current_streak=(stats.current_streak||0)+1;
  } else {
    stats.current_streak=1;
  }
  if(stats.current_streak>stats.longest_streak)stats.longest_streak=stats.current_streak;
  stats.last_call_date=today;
  stats.updated_at=new Date().toISOString();
  await sb.from('vendor_stats').upsert(stats,{onConflict:'vendor_name'});
  VENDOR_STATS_CACHE[vendor]=stats;
}

function getStreakIcon(vendor){
  const stats=VENDOR_STATS_CACHE[vendor];
  if(!stats||!stats.current_streak||stats.current_streak<1)return'';
  const streak=stats.current_streak;
  let color='#db6d28',size='16';
  if(streak>=7){color='var(--purple)';size='22';}
  else if(streak>=4){color='var(--red)';size='19';}
  return'<span title="'+streak+' day streak" style="font-size:'+size+'px;margin-left:6px;vertical-align:middle">&#128293;</span>';
}

// ====== DAILY CHALLENGES ======
const DAILY_CHALLENGES=[
  {day:1,label:'Faire 15 appels',target:15,type:'calls',points:50},
  {day:2,label:'3 clients interesses',target:3,type:'interested',points:40},
  {day:3,label:'Completer une region de projet',target:1,type:'region_complete',points:100},
  {day:4,label:'Gagner 2 ventes',target:2,type:'wins',points:150},
  {day:5,label:'Appeler 20 prospects',target:20,type:'calls',points:30}
];

function getDailyChallenge(){
  const dayOfWeek=new Date().getDay();
  if(dayOfWeek===0||dayOfWeek===6)return DAILY_CHALLENGES[4];
  return DAILY_CHALLENGES[dayOfWeek-1];
}

function getDailyChallengeProgress(vendor){
  const challenge=getDailyChallenge();
  const today=new Date().toISOString().slice(0,10);
  const todayCalls=CALL_HISTORY.filter(c=>c.vendor===vendor&&c.created_at&&c.created_at.slice(0,10)===today);

  switch(challenge.type){
    case 'calls': return Math.min(todayCalls.length,challenge.target);
    case 'interested': return Math.min(todayCalls.filter(c=>c.result==='interested').length,challenge.target);
    case 'wins': return Math.min(DATA.filter(d=>d.vendeur===vendor&&d.status==='valide'&&d.updated_at&&d.updated_at.slice(0,10)===today).length,challenge.target);
    case 'region_complete': return 0;
    default: return 0;
  }
}

function renderDailyChallenge(vendor){
  const ch=getDailyChallenge();
  const progress=getDailyChallengeProgress(vendor);
  const pct=Math.min((progress/ch.target)*100,100);
  const completed=progress>=ch.target;
  return '<div style="background:rgba(22,27,34,0.8);backdrop-filter:blur(12px);border:1px solid '+(completed?'var(--green)':'rgba(88,166,255,0.15)')+';border-radius:12px;padding:16px;margin:0 24px 12px">'+
    '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">'+
    '<span style="font-size:.72rem;font-weight:700">'+
    (completed?'&#9989; ':'&#127919; ')+'Defi du jour: '+ch.label+'</span>'+
    '<span style="font-size:.68rem;font-weight:700;color:'+(completed?'var(--green)':'var(--accent)')+'">+'+ch.points+' pts</span>'+
    '</div>'+
    '<div style="width:100%;height:6px;background:var(--s3);border-radius:3px;overflow:hidden">'+
    '<div style="width:'+pct+'%;height:100%;background:'+(completed?'var(--green)':'var(--accent)')+';border-radius:3px;transition:width .4s;'+(completed?'':'animation:shimmer 2s infinite')+'"></div>'+
    '</div>'+
    '<div style="font-size:.58rem;color:var(--gray);margin-top:4px">'+progress+'/'+ch.target+'</div>'+
    '</div>';
}

function showBadgeUnlock(badge){
  const overlay=document.createElement('div');
  overlay.style.cssText='position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:10000;display:flex;flex-direction:column;align-items:center;justify-content:center;';
  overlay.innerHTML=`
    <div id="unlockBadgeIcon" style="width:80px;height:80px;display:flex;align-items:center;justify-content:center;font-size:2.5rem">${badge.icon}</div>
    <div id="unlockBadgeName" style="font-size:1.5rem;font-weight:800;margin-top:16px;color:var(--yellow);opacity:0">${badge.name}</div>
    <div style="font-size:.8rem;color:var(--gray);margin-top:8px;opacity:0" id="unlockBadgeDesc">${badge.desc}</div>
    <div style="font-size:1rem;font-weight:700;color:var(--yellow);margin-top:12px;opacity:0" id="unlockBadgePts">+${badge.points} pts</div>
    <div style="font-size:.7rem;text-transform:uppercase;letter-spacing:.2em;color:var(--accent);margin-top:20px;opacity:0" id="unlockLabel">NEW BADGE UNLOCKED</div>
  `;
  document.body.appendChild(overlay);
  gsap.fromTo('#unlockBadgeIcon',{scale:0},{scale:1,duration:.6,ease:'elastic.out(1,.5)'});
  gsap.to('#unlockBadgeName',{opacity:1,delay:.4,duration:.4});
  gsap.to('#unlockBadgeDesc',{opacity:1,delay:.6,duration:.4});
  gsap.to('#unlockBadgePts',{opacity:1,y:-5,delay:.8,duration:.4});
  gsap.to('#unlockLabel',{opacity:1,delay:1,duration:.4});
  showConfetti();
  setTimeout(()=>{gsap.to(overlay,{opacity:0,duration:.4,onComplete:()=>overlay.remove()})},3000);
}

function editPipeNote(el,id){
  if(el.querySelector('textarea'))return;
  const full=el.dataset.full||'';
  el.innerHTML='<textarea maxlength="200" placeholder="Add note...">'+escHtml(full)+'</textarea><div class="pipe-card-notes-footer"><span class="pipe-card-notes-saved" id="noteSaved_'+id+'">Saved \u2713</span><span id="noteCount_'+id+'">'+full.length+'/200</span></div>';
  const ta=el.querySelector('textarea');
  ta.focus();
  ta.addEventListener('input',function(){document.getElementById('noteCount_'+id).textContent=ta.value.length+'/200'});
  ta.addEventListener('blur',async function(){
    const val=ta.value.trim();
    await sb.from('prospects').update({notes:val,updated_at:new Date().toISOString()}).eq('id',id);
    const row=DATA.find(function(d){return d.id===id});if(row)row.notes=val;
    el.dataset.full=val;
    const saved=document.getElementById('noteSaved_'+id);
    if(saved){saved.classList.add('show');setTimeout(function(){saved.classList.remove('show')},2000)}
    setTimeout(function(){
      const txt=val?(val.length>60?val.substring(0,60)+'...':val):'';
      el.innerHTML='<div class="pipe-card-notes-text'+(val?'':' empty')+'">'+(val?escHtml(txt):'Add note...')+'</div>';
      el.onclick=function(){editPipeNote(el,id)};
    },2500);
  });
  el.onclick=null;
}

function checkBadges(vendor){
  const vd=DATA.filter(d=>d.vendeur===vendor);
  const calls=CALL_HISTORY.filter(c=>c.vendor===vendor).length;
  const wins=vd.filter(d=>d.status==='valide').length;
  const rev=CLIENTS.filter(c=>c.vendor_name===vendor&&c.site_status!=='cancelled').reduce((s,c)=>s+(parseFloat(c.sale_price)||0),0);
  const nego=vd.filter(d=>d.status==='negociation').length;
  const pts=calcPoints(vendor);
  const notes=vd.filter(d=>d.notes&&d.notes.trim()).length;

  if(calls>=1)unlockBadge(vendor,'first_dial');
  if(calls>=3)unlockBadge(vendor,'rookie');
  if(calls>=10)unlockBadge(vendor,'dialer');
  if(calls>=25)unlockBadge(vendor,'call_center');
  if(calls>=50)unlockBadge(vendor,'phone_warrior');
  if(calls>=100)unlockBadge(vendor,'century_caller');
  if(calls>=200)unlockBadge(vendor,'marathon_caller');
  if(calls>=500)unlockBadge(vendor,'legend_caller');
  if(wins>=1)unlockBadge(vendor,'first_sale');
  if(wins>=10)unlockBadge(vendor,'closer');
  if(wins>=25)unlockBadge(vendor,'elite_closer');
  if(wins>=50)unlockBadge(vendor,'master_closer');
  if(wins>=20)unlockBadge(vendor,'hall_of_fame');
  if(rev>=500)unlockBadge(vendor,'first_500');
  if(rev>=1000)unlockBadge(vendor,'money_maker');
  if(rev>=5000)unlockBadge(vendor,'grand');
  if(rev>=10000){unlockBadge(vendor,'high_roller');unlockBadge(vendor,'money_printer');}
  if(rev>=25000)unlockBadge(vendor,'revenue_king');
  if(rev>=50000)unlockBadge(vendor,'revenue_god');
  if(pts>=500){unlockBadge(vendor,'bonus_hunter');unlockBadge(vendor,'vantage_elite');}
  if(pts>=1000){unlockBadge(vendor,'double_bonus');unlockBadge(vendor,'vantage_legend');}
  if(pts>=2000)unlockBadge(vendor,'vantage_god');
  if(notes>=1)unlockBadge(vendor,'hello_world');
  if(notes>=50)unlockBadge(vendor,'note_master');
  if(nego>=10)unlockBadge(vendor,'negotiator');
  if(vd.filter(d=>d.status==='negociation'&&d.notes).length>=5)unlockBadge(vendor,'follow_up_pro');
  const regions=[...new Set(vd.map(d=>d.region).filter(Boolean))];
  if(regions.length>=1)unlockBadge(vendor,'on_the_map');
  if(regions.length>=3)unlockBadge(vendor,'island_hopper');

  const unlockedCount=Object.values(getBadges(vendor)).filter(b=>b.unlocked).length;
  if(unlockedCount>=50)unlockBadge(vendor,'completionist');
  if(unlockedCount>=80)unlockBadge(vendor,'vantage_champion');
}

// ========================================
// CALL SCRIPTS
// ========================================
const CALL_SCRIPT_GR='\u0393\u03B5\u03B9\u03B1 \u03C3\u03B1\u03C2! \u039C\u03B5 \u03BB\u03AD\u03BD\u03B5 [name]. \u03A0\u03B1\u03C1\u03B1\u03C4\u03AE\u03C1\u03B7\u03C3\u03B1 \u03CC\u03C4\u03B9 \u03B7 \u03B5\u03C0\u03B9\u03C7\u03B5\u03AF\u03C1\u03B7\u03C3\u03AE \u03C3\u03B1\u03C2 \u03B4\u03B5\u03BD \u03AD\u03C7\u03B5\u03B9 \u03B9\u03C3\u03C4\u03BF\u03C3\u03B5\u03BB\u03AF\u03B4\u03B1 \u2014 \u03BC\u03C0\u03BF\u03C1\u03CE \u03BD\u03B1 \u03C3\u03B1\u03C2 \u03C6\u03C4\u03B9\u03AC\u03BE\u03C9 \u03BC\u03B9\u03B1 \u03B5\u03C0\u03B1\u03B3\u03B3\u03B5\u03BB\u03BC\u03B1\u03C4\u03B9\u03BA\u03AE \u03C3\u03B5 5 \u03BC\u03AD\u03C1\u03B5\u03C2. \u03A3\u03B1\u03C2 \u03B5\u03BD\u03B4\u03B9\u03B1\u03C6\u03AD\u03C1\u03B5\u03B9;';
const CALL_SCRIPT_EN='Hi! I\'m [name]. I noticed your business doesn\'t have a website \u2014 I can build you a professional one in 5 days. Interested?';

const OBJECTIONS={
  expensive:{label:'Too expensive / \u0391\u03BA\u03C1\u03B9\u03B2\u03CC',en:'One new client/month covers it. One-time 500\u20AC investment.',gr:'\u0388\u03BD\u03B1\u03C2 \u03BD\u03AD\u03BF\u03C2 \u03C0\u03B5\u03BB\u03AC\u03C4\u03B7\u03C2/\u03BC\u03AE\u03BD\u03B1 \u03C4\u03BF \u03BA\u03B1\u03BB\u03CD\u03C0\u03C4\u03B5\u03B9. \u0395\u03C6\u03AC\u03C0\u03B1\u03BE \u03B5\u03C0\u03AD\u03BD\u03B4\u03C5\u03C3\u03B7 500\u20AC.'},
  have_site:{label:'Already have site / \u0388\u03C7\u03C9 \u03AE\u03B4\u03B7',en:'I can check it \u2014 most sites lose clients. I rebuild better for 300\u20AC.',gr:'\u039C\u03C0\u03BF\u03C1\u03CE \u03BD\u03B1 \u03C4\u03BF \u03B5\u03BB\u03AD\u03B3\u03BE\u03C9 \u2014 \u03BF\u03B9 \u03C0\u03B5\u03C1\u03B9\u03C3\u03C3\u03CC\u03C4\u03B5\u03C1\u03B5\u03C2 \u03B9\u03C3\u03C4\u03BF\u03C3\u03B5\u03BB\u03AF\u03B4\u03B5\u03C2 \u03C7\u03AC\u03BD\u03BF\u03C5\u03BD \u03C0\u03B5\u03BB\u03AC\u03C4\u03B5\u03C2. \u03A4\u03BF \u03BE\u03B1\u03BD\u03B1\u03C6\u03C4\u03B9\u03AC\u03C7\u03BD\u03C9 \u03BA\u03B1\u03BB\u03CD\u03C4\u03B5\u03C1\u03B1 \u03B3\u03B9\u03B1 300\u20AC.'},
  no_time:{label:'No time / \u0394\u03B5\u03BD \u03AD\u03C7\u03C9 \u03C7\u03C1\u03CC\u03BD\u03BF',en:'You don\'t do anything \u2014 send info+photos, I handle everything.',gr:'\u0394\u03B5\u03BD \u03C7\u03C1\u03B5\u03B9\u03AC\u03B6\u03B5\u03C4\u03B1\u03B9 \u03BD\u03B1 \u03BA\u03AC\u03BD\u03B5\u03C4\u03B5 \u03C4\u03AF\u03C0\u03BF\u03C4\u03B1 \u2014 \u03C3\u03C4\u03B5\u03AF\u03BB\u03C4\u03B5 \u03C0\u03BB\u03B7\u03C1\u03BF\u03C6\u03BF\u03C1\u03AF\u03B5\u03C2+\u03C6\u03C9\u03C4\u03BF\u03B3\u03C1\u03B1\u03C6\u03AF\u03B5\u03C2, \u03C4\u03B1 \u03B1\u03BD\u03B1\u03BB\u03B1\u03BC\u03B2\u03AC\u03BD\u03C9 \u03CC\u03BB\u03B1.'}
};

