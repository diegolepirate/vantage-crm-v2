/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/*.html
  Cache-Control: no-cache, no-store, must-revalidate

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/assets/models/*
  Cache-Control: public, max-age=3600, must-revalidate

/*
  Cache-Control: no-cache, no-store, must-revalidate
